– Remote cooldown registry
local RemoteCooldowns = {}
local REMOTE_COOLDOWN = 0.25

local function canFire(key)
local now = tick()
if (RemoteCooldowns[key] or 0) + REMOTE_COOLDOWN > now then return false end
RemoteCooldowns[key] = now
return true
end

– Safe CommF_ invoke with cooldown
local function CommF(…)
local r = Rep:FindFirstChild(“Remotes”)
r = r and r:FindFirstChild(“CommF_”)
if not r then return nil end
local key = tostring(r) .. tostring((…))
if not canFire(key) then return nil end
local ok, res = pcall(function(…) return r:InvokeServer(…) end, …)
if ok then return res end
return nil
end

