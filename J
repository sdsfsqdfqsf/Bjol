local _invCache, _invCacheTime = {}, 0
local INV_CACHE_TTL = 2

local function getInventory()
local now = tick()
if now - _invCacheTime < INV_CACHE_TTL then return _invCache end
local result = CommF(“getInventory”)
if result then
_invCache = result
_invCacheTime = now
end
return _invCache
end

GetM = function(Name)
for _, tab in pairs(getInventory()) do
if type(tab) == “table” and tab.Type == “Material” and tab.Name == Name then
return tab.Count or 0
end
end
return 0
end

GetIn = function(Name)
for _, v in pairs(getInventory()) do
if type(v) == “table” and v.Name == Name then return true end
end
return GetBP(Name) ~= nil
end

