local _tpDebounce = false
local _tpDebounceTime = 0

_tp = function(target)
if not target then return end
– Character guard
local c = plr.Character
if not c then return end
local root = c:FindFirstChild(“HumanoidRootPart”)
if not root then return end
– Distance skip (already there)
if (target.Position - root.Position).Magnitude < 3 then return end

if not block or not block.Parent then return end
local dist = (target.Position - root.Position).Magnitude
local speed = math.clamp(dist, 50, 500)
local ti = TweenInfo.new(dist / speed, Enum.EasingStyle.Linear)
local tw = TweenService:Create(block, ti, {CFrame = target})

local hum = c:FindFirstChild(“Humanoid”)
if hum and hum.Sit then
block.CFrame = CFrame.new(block.Position.X, target.Y, block.Position.Z)
end
tw:Play()
task.spawn(function()
while tw.PlaybackState == Enum.PlaybackState.Playing do
if not shouldTween then tw:Cancel(); break end
task.wait(0.1)
end
end)
end

