local function makeESPLabel(parent, text, color, yOffset)
local old = parent:FindFirstChild(“HubESP”)
if old then old:Destroy() end
local bb = Instance.new(“BillboardGui”)
bb.Name          = “HubESP”
bb.AlwaysOnTop   = true
bb.Size          = UDim2.new(0,200,0,55)
bb.StudsOffset   = Vector3.new(0, yOffset or 3, 0)
bb.Parent        = parent
local lbl = Instance.new(“TextLabel”, bb)
lbl.BackgroundTransparency = 1
lbl.Size                   = UDim2.new(1,0,1,0)
lbl.TextColor3             = color or Color3.new(1,1,1)
lbl.TextStrokeTransparency = 0
lbl.TextStrokeColor3       = Color3.new(0,0,0)
lbl.Font                   = Enum.Font.GothamBold
lbl.TextScaled             = true
lbl.Text                   = text
return bb, lbl
end

local function addHL(model, fill, outline)
if model:FindFirstChild(“HubHL”) then return end
local h = Instance.new(“Highlight”)
h.Name               = “HubHL”
h.FillColor          = fill    or Color3.fromRGB(255,50,50)
h.OutlineColor       = outline or Color3.fromRGB(255,255,255)
h.FillTransparency   = 0.5
h.OutlineTransparency= 0
h.Parent             = model
end

local function clearESP()
for _, obj in pairs(_espObjs) do
pcall(function()
if obj:FindFirstChild(“HubESP”) then obj.HubESP:Destroy() end
if obj:FindFirstChild(“HubHL”)  then obj.HubHL:Destroy() end
end)
end
